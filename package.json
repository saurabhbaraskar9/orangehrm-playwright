{
  "name": "orangehrm-playwright",
  "version": "1.0.0",
  "description": "Playwright with TypeScript Automation Framework for OrangeHRM Demo Application.",
  "main": "index.js",
  "scripts": {
  "pretest": "rimraf allure-results test-results playwright-report",
  "test": "playwright test",
  "test:ci": "playwright test --project=chromium",
  "test:headed": "playwright test --headed",
  "test:debug": "playwright test --debug",
  "test:ui": "playwright test --ui",
  "test:chrome": "playwright test --project=chromium",
  "test:firefox": "playwright test --project=firefox",
  "test:auth": "playwright test tests/auth/",
  "test:employee": "playwright test tests/employee/",
  "report:html": "playwright show-report",
  "allure:env": "node scripts/allure-environment.js",
  "allure:generate": "npm run allure:env && allure generate allure-results --clean -o allure-report",
  "allure:open": "allure open allure-report",
  "report:allure": "npm run allure:generate && npm run allure:open",
  "lint": "eslint . --ext .ts",
  "lint:fix": "eslint . --ext .ts --fix",
  "format": "prettier --write ."
},
  "author": "Saurabh Baraskar",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "allure-commandline": "^2.42.1",
    "allure-playwright": "^3.10.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.4",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsconfig-paths": "^4.2.0"
  }
}
