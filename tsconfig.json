{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@utils/*": ["src/utils/*"],
      "@components/*": ["src/components/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@config/*": ["config/*"],
      "@types-custom/*": ["src/types/*"]
    },
    "outDir": "./dist"
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "config/**/*",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}